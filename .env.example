# Supabase project credentials (client-safe — the anon key is protected by RLS)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI is BYOK (bring your own key): users paste an Anthropic or OpenAI key into the
# app's Settings; it's stored in their browser. No server-side AI key is needed.
