# Supabase project credentials (client-safe — the anon key is protected by RLS)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Server-side only (set as Supabase Edge Function secrets, NEVER prefixed VITE_) ---
# Set with: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...
